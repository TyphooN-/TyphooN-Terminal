services:
  lan-server:
{% if typhoon_lan_server_build_context | length > 0 %}
    build:
      context: {{ typhoon_lan_server_build_context | to_json }}
      dockerfile: {{ typhoon_lan_server_build_dockerfile | to_json }}
{% endif %}
    image: {{ typhoon_lan_server_image | to_json }}
    container_name: {{ typhoon_lan_server_container_name | to_json }}
    restart: unless-stopped
    command:
      - --lan-server
      - --cache-dir
      - /cache
      - --lan-port
      - "{{ typhoon_lan_server_lan_port }}"
      - --metrics-port
      - "{{ typhoon_lan_server_metrics_port }}"
    environment:
      TYPHOON_CACHE_DIR: /cache
{% if typhoon_lan_server_bootstrap_passphrase | length > 0 %}
      TYPHOON_LAN_PASSPHRASE: {{ typhoon_lan_server_bootstrap_passphrase | to_json }}
{% endif %}
      RUST_LOG: {{ typhoon_lan_server_rust_log | to_json }}
    volumes:
      - type: bind
        source: {{ typhoon_lan_server_cache_host_path | to_json }}
        target: /cache
    ports:
      - "{{ typhoon_lan_server_lan_port }}:9847"
      - "{{ typhoon_lan_server_metrics_port }}:9090"
    healthcheck:
      test: ["CMD", "typhoon-cli", "--help"]
      interval: 60s
      timeout: 10s
      retries: 3
      start_period: 5s
{% if typhoon_lan_server_prometheus_enabled | bool %}

  prometheus:
    image: {{ typhoon_lan_server_prometheus_image | to_json }}
    restart: unless-stopped
    command:
      - --config.file=/etc/prometheus/prometheus.yml
      - --storage.tsdb.path=/prometheus
      - --storage.tsdb.retention.time={{ typhoon_lan_server_prometheus_retention }}
      - --web.enable-lifecycle
    volumes:
      - ./prometheus/prometheus.yml:/etc/prometheus/prometheus.yml:ro
      - prometheus-data:/prometheus
    ports:
      - "{{ typhoon_lan_server_prometheus_port }}:9090"
    depends_on:
      - lan-server
{% endif %}
{% if typhoon_lan_server_grafana_enabled | bool %}

  grafana:
    image: {{ typhoon_lan_server_grafana_image | to_json }}
    restart: unless-stopped
    environment:
      GF_SECURITY_ADMIN_USER: {{ typhoon_lan_server_grafana_admin_user | to_json }}
      GF_SECURITY_ADMIN_PASSWORD: {{ typhoon_lan_server_grafana_admin_password | to_json }}
      GF_USERS_ALLOW_SIGN_UP: "false"
    volumes:
      - grafana-data:/var/lib/grafana
      - ./grafana/provisioning:/etc/grafana/provisioning:ro
      - ./grafana/dashboards:/var/lib/grafana/dashboards:ro
    ports:
      - "{{ typhoon_lan_server_grafana_port }}:3000"
{% if typhoon_lan_server_prometheus_enabled | bool %}
    depends_on:
      - prometheus
{% endif %}
{% endif %}
{% if typhoon_lan_server_kafka_enabled | bool %}

  kafka:
    image: {{ typhoon_lan_server_kafka_image | to_json }}
    hostname: kafka
    restart: unless-stopped
    environment:
      KAFKA_NODE_ID: 1
      KAFKA_LISTENER_SECURITY_PROTOCOL_MAP: CONTROLLER:PLAINTEXT,PLAINTEXT:PLAINTEXT,PLAINTEXT_HOST:PLAINTEXT
      KAFKA_ADVERTISED_LISTENERS: "PLAINTEXT_HOST://{{ typhoon_lan_server_kafka_advertised_host }}:{{ typhoon_lan_server_kafka_port }},PLAINTEXT://kafka:19092"
      KAFKA_PROCESS_ROLES: broker,controller
      KAFKA_CONTROLLER_QUORUM_VOTERS: 1@kafka:29093
      KAFKA_LISTENERS: CONTROLLER://:29093,PLAINTEXT_HOST://:9092,PLAINTEXT://:19092
      KAFKA_INTER_BROKER_LISTENER_NAME: PLAINTEXT
      KAFKA_CONTROLLER_LISTENER_NAMES: CONTROLLER
      CLUSTER_ID: {{ typhoon_lan_server_kafka_cluster_id | to_json }}
      KAFKA_OFFSETS_TOPIC_REPLICATION_FACTOR: 1
      KAFKA_GROUP_INITIAL_REBALANCE_DELAY_MS: 0
      KAFKA_TRANSACTION_STATE_LOG_MIN_ISR: 1
      KAFKA_TRANSACTION_STATE_LOG_REPLICATION_FACTOR: 1
      KAFKA_SHARE_COORDINATOR_STATE_TOPIC_REPLICATION_FACTOR: 1
      KAFKA_SHARE_COORDINATOR_STATE_TOPIC_MIN_ISR: 1
      KAFKA_LOG_DIRS: /tmp/kraft-combined-logs
    volumes:
      - kafka-data:/tmp/kraft-combined-logs
    ports:
      - "{{ typhoon_lan_server_kafka_port }}:9092"
    healthcheck:
      test: ["CMD", "/opt/kafka/bin/kafka-topics.sh", "--bootstrap-server", "localhost:9092", "--list"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 30s
{% endif %}

{% if (typhoon_lan_server_prometheus_enabled | bool) or (typhoon_lan_server_grafana_enabled | bool) or (typhoon_lan_server_kafka_enabled | bool) %}
volumes:
{% if typhoon_lan_server_prometheus_enabled | bool %}
  prometheus-data:
{% endif %}
{% if typhoon_lan_server_grafana_enabled | bool %}
  grafana-data:
{% endif %}
{% if typhoon_lan_server_kafka_enabled | bool %}
  kafka-data:
{% endif %}
{% endif %}
