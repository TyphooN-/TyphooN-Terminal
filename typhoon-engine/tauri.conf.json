{
  "$schema": "https://raw.githubusercontent.com/nicholasrice/tauri/HEAD/crates/tauri-schema-generator/schemas/config.schema.json",
  "productName": "TyphooN-Terminal",
  "version": "0.1.0",
  "identifier": "org.typhoon.typhoon-terminal",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico", "icons/icon.png"],
    "targets": "all"
  },
  "app": {
    "windows": [
      {
        "title": "TyphooN Terminal",
        "width": 1600,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'none'"
    },
    "withGlobalTauri": true
  }
}
